{
  "name": "ktoolbox-webui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "generate:api": "poetry run python ../scripts/export_webui_openapi.py && openapi-typescript openapi.json -o src/generated/api.ts",
    "check:api": "npm run generate:api && git diff --exit-code -- openapi.json src/generated/api.ts",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@hookform/resolvers": "^5.2.2",
    "@internationalized/date": "^3.12.2",
    "@tabler/icons-react": "^3.45.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.90.21",
    "i18next": "^25.8.18",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "js-yaml": "^4.3.0"
  }
}
