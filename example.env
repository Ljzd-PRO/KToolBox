##############################################################################
# KToolBox reads `.env`, then `prod.env`, from the current working directory. #
# All values are optional. Run `ktoolbox example-env` for every available key. #
##############################################################################

# Pawchive defaults. Overrides are normally unnecessary.
#KTOOLBOX_API__SCHEME=https
#KTOOLBOX_API__NETLOC=pawchive.pw
#KTOOLBOX_API__STATICS_NETLOC=pawchive.pw
#KTOOLBOX_API__PATH=/api/v1
#KTOOLBOX_DOWNLOADER__FILES_NETLOC=file.pawchive.pw
#KTOOLBOX_DOWNLOADER__FILE_PATH_PREFIX=/data

# Optional cookie sent only to file downloads. API requests never use it.
#KTOOLBOX_DOWNLOADER__SESSION_KEY=xxxxx

# Download four files concurrently.
KTOOLBOX_JOB__COUNT=4

# Save attachments directly in each post directory.
#KTOOLBOX_JOB__POST_STRUCTURE__ATTACHMENTS=./

# Rename attachments in numeric order while preserving selected extensions.
#KTOOLBOX_JOB__SEQUENTIAL_FILENAME=True
#KTOOLBOX_JOB__SEQUENTIAL_FILENAME_EXCLUDES='[".psd", ".zip", ".mp4"]'

# Customize directories and filenames with Post fields.
#KTOOLBOX_JOB__POST_DIRNAME_FORMAT=[{published}]{title:.60}
#KTOOLBOX_JOB__FILENAME_FORMAT=[{published}]_{title:.60}_{id}_{}

# Choose what to download and optionally enforce byte-size limits.
#KTOOLBOX_JOB__DOWNLOAD_FILE=True
#KTOOLBOX_JOB__DOWNLOAD_ATTACHMENTS=True
#KTOOLBOX_JOB__MIN_FILE_SIZE=1024
#KTOOLBOX_JOB__MAX_FILE_SIZE=1048576

# Filter attachment names with Unix shell patterns.
#KTOOLBOX_JOB__ALLOW_LIST='["*.jpg", "*.png"]'
#KTOOLBOX_JOB__BLOCK_LIST='["*.zip", "*.psd"]'
